# Tuple Slicing
# Slicing is used to extract part of a tuple.

items = ("apple", "banana", "orange", "mango")
 
print(items[1:3])
print(items[:2])
print(items[2:])



# Negative Indexing
# Negative indexes start from the end of the tuple.

items = ("apple", "banana", "orange")
 
print(items[-1])
print(items[-2])